{
  "name": "fastify-boilerplate",
  "version": "1.0.0",
  "description": "Production-ready Fastify TypeScript boilerplate with Better Auth, Prisma, BullMQ, Socket.io, and Stripe.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"pnpm watch:ts\" \"pnpm dev:start\"",
    "dev:start": "node --watch dist/index.js",
    "watch:ts": "tsc -w",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "keywords": ["fastify", "typescript", "boilerplate", "rest-api"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@better-auth/prisma-adapter": "^1.6.20",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.20",
    "bullmq": "^5.79.1",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "ejs": "^6.0.1",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "concurrently": "^9.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "fastify-tsconfig": "^3.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "typescript": "~5.9.2"
  }
}
